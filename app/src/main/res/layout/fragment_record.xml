<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="20dp">

    <com.yago.grabadora.WaveformView
        android:id="@+id/waveform"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace"
        android:text="00:00"
        android:textColor="?attr/colorOnSurface"
        android:textSize="46sp" />

    <LinearLayout
        android:id="@+id/playerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/playTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:fontFamily="monospace"
            android:text="00:00" />

        <SeekBar
            android:id="@+id/seek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <ImageButton
            android:id="@+id/mainBtn"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/record_red"
            android:contentDescription="grabar"
            android:padding="22dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_mic"
            app:tint="@color/white" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/pausedPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:visibility="gone"
        android:weightSum="4">

        <ImageButton
            android:id="@+id/btnDiscard"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Descartar"
            android:padding="16dp"
            android:src="@drawable/ic_close"
            app:tint="@color/record_red" />

        <ImageButton
            android:id="@+id/btnResume"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Reanudar"
            android:padding="16dp"
            android:src="@drawable/ic_circle"
            app:tint="@color/record_red" />

        <ImageButton
            android:id="@+id/btnListen"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Escuchar"
            android:padding="16dp"
            android:src="@drawable/ic_play"
            app:tint="?attr/colorPrimary" />

        <ImageButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Guardar"
            android:padding="16dp"
            android:src="@drawable/ic_save"
            app:tint="?attr/colorPrimary" />
    </LinearLayout>
</LinearLayout>
